# Kopiere nach .env und trage echte Werte ein (.env nicht committen).
# Start: npm start  oder  docker compose up -d --build

# ——— Allgemein ———
NODE_ENV=production
APP_HOST=0.0.0.0
APP_PORT=3847
# Öffentliche URL (Domain mit https) — für Links und Produktion
APP_PUBLIC_URL=https://app.deine-domain.de
APP_SERVE_STATIC=true
TRUST_PROXY=true
# Kommagetrennt; leer = gleiche Origin (App und API unter einer Domain)
APP_CORS_ORIGINS=

# ——— Sicherheit (Pflicht in Produktion) ———
# Mindestens 32 Zeichen: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ——— PostgreSQL ———
# Lokal mit Docker: postgres://immobiliencheck:immobiliencheck_dev_password@db:5432/immobiliencheck
# Hetzner Managed DB oder Postgres auf CX33:
DATABASE_URL=postgres://USER:PASS@HOST:5432/immobiliencheck
PG_POOL_MAX=20

# ——— Hetzner Object Storage (S3-kompatibel) ———
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=immobiliencheck-prod
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

# ——— Uploads ———
UPLOAD_MAX_MB=25

# ——— SMTP — automatischer Kundenbericht ———
# Bei Freigabe einer Checkliste / Arbeitsauftrag sendet der Server das PDF per E-Mail.
# Ohne diese Werte: nur mailto:-Entwurf oder Download-Fallback im Browser.
# IONOS (DE): smtp.ionos.de — Port 587 (Hetzner blockiert oft 465). SMTP_FROM in Anführungszeichen.
MAIL_ENABLED=true
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Immobiliencheck <berichte@deine-domain.de>

# ——— Erstbenutzer (npm run seed im Backend-Container/Ordner) ———
# SEED_PASSWORD_CHEF=
# SEED_PASSWORD_PATRICK_ADMIN=   # voller Chef-Zugang (username patrick_admin)
# SEED_PASSWORD_PATRICK=
# SEED_PASSWORD_KRISTINA=

# ——— Nur lokale Entwicklung ohne Docker (optional) ———
# NODE_ENV=development
# DATABASE_URL=postgres://immobiliencheck:immobiliencheck_dev_password@127.0.0.1:5432/immobiliencheck
# JWT_SECRET wird im Dev-Modus automatisch gesetzt, S3 kann leer bleiben (Uploads fehlschlagen dann).
