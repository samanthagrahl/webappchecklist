# Instanz-Konfiguration für {{DISPLAY_NAME}} ({{SLUG}})
# Auf dem Server kopieren nach: /opt/immobiliencheck/customers/{{SLUG}}/instance.env
# Symlink oder EnvironmentFile in systemd auf diese Datei zeigen.
# NIEMALS committen — nur instance.env.example im Git.

# ——— Allgemein ———
NODE_ENV=production
APP_HOST=0.0.0.0
APP_PORT={{APP_PORT}}
APP_PUBLIC_URL=https://{{FQDN}}
APP_SERVE_STATIC=true
TRUST_PROXY=true
APP_CORS_ORIGINS=

# ——— Sicherheit (pro Instanz einzigartig!) ———
# Generieren: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ——— PostgreSQL (eigene Datenbank pro Kunde) ———
# Format: postgres://USER:PASS@HOST:PORT/DATABASE
DATABASE_URL=postgres://USER:PASS@HOST:5432/immobiliencheck_{{SLUG_UNDERSCORE}}
PG_POOL_MAX=20

# ——— Hetzner Object Storage (eigener Bucket pro Kunde) ———
S3_ENDPOINT={{S3_ENDPOINT}}
S3_REGION={{S3_REGION}}
S3_BUCKET=immobiliencheck-{{SLUG}}
S3_ACCESS_KEY_ID={{S3_ACCESS_KEY_ID}}
S3_SECRET_ACCESS_KEY={{S3_SECRET_ACCESS_KEY}}
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

UPLOAD_MAX_MB=25

# ——— SMTP (Kundenberichte) ———
MAIL_ENABLED=true
SMTP_HOST={{SMTP_HOST}}
SMTP_PORT={{SMTP_PORT}}
SMTP_SECURE={{SMTP_SECURE}}
SMTP_REQUIRE_TLS={{SMTP_REQUIRE_TLS}}
SMTP_USER={{SMTP_USER}}
SMTP_PASS={{SMTP_PASS}}
SMTP_FROM=Immobiliencheck <berichte@{{BASE_DOMAIN}}>

# ——— Erst-Admin (nur für npm run upsert-boss-user, nicht dauerhaft in .env lassen) ———
# ADMIN_USERNAME=chef
# ADMIN_PASSWORD=
# ADMIN_LABEL=Chef ({{DISPLAY_NAME}})
