# Instanz-Konfiguration für Kunde A
# Auf dem Server: cp instance.env.example instance.env && nano instance.env
# Pfad auf Server: /opt/immobiliencheck/customers/kunde-a/instance.env

# ——— Allgemein ———
NODE_ENV=production
APP_HOST=0.0.0.0
APP_PORT=3847
APP_PUBLIC_URL=https://kunde-a.deine-domain.de
APP_SERVE_STATIC=true
TRUST_PROXY=true
APP_CORS_ORIGINS=

# ——— Sicherheit (pro Instanz einzigartig!) ———
JWT_SECRET=
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ——— PostgreSQL ———
DATABASE_URL=postgres://USER:PASS@HOST:5432/immobiliencheck_kunde_a
PG_POOL_MAX=20

# ——— Hetzner Object Storage ———
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=immobiliencheck-kunde-a
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

UPLOAD_MAX_MB=25

# ——— SMTP ———
MAIL_ENABLED=true
SMTP_HOST=smtp.deine-domain.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Immobiliencheck <berichte@deine-domain.de>

# ——— Erst-Admin (nur einmalig für upsert-boss-user) ———
# ADMIN_USERNAME=chef
# ADMIN_PASSWORD=
# ADMIN_LABEL=Chef (Kunde A)
